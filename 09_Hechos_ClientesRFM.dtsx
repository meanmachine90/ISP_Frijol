            <component
              refId="Package\Hechos_Clientes\Origen de ADO NET"
              componentClassID="Microsoft.ManagedComponentHost"
              contactInfo="Consume datos de SQL Server, OLE DB, ODBC u Oracle mediante el correspondiente proveedor de datos de .NET Framework. Se usa una instrucción Transact-SQL para definir el conjunto de resultados. Por ejemplo, se extraen datos de SQL Server con el proveedor de datos de .NET Framework para SQL Server.;Microsoft Corporation; Microsoft SQL Server; © Microsoft Corporation; Todos los derechos reservados; http://www.microsoft.com/sql/support;4"
              description="Consume datos de SQL Server, OLE DB, ODBC u Oracle mediante el correspondiente proveedor de datos de .NET Framework. Se usa una instrucción Transact-SQL para definir el conjunto de resultados. Por ejemplo, se extraen datos de SQL Server con el proveedor de datos de .NET Framework para SQL Server."
              name="Origen de ADO NET"
              usesDispositions="true"
              version="4">
              <properties>
                <property
                  dataType="System.String"
                  description="Especifica la instrucción SQL utilizada por el componente para extraer datos."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">;WITH RFM AS (
    SELECT
        c.ID_CLIENTE AS CodigoCliente,
        ISNULL(DATEDIFF(DAY, MAX(v.FECHA_VENTA), GETDATE()), 9999) AS Recency,
        COUNT(DISTINCT v.ID_VENTA) AS Frequency,
        ISNULL(SUM(v.TOTAL), 0)    AS Monetary
    FROM DbMultidimensionales_Proyecto3_Frijol.dbo.CLIENTES c
    LEFT JOIN DbMultidimensionales_Proyecto3_Frijol.dbo.VENTAS v ON c.ID_CLIENTE = v.ID_CLIENTE
    GROUP BY c.ID_CLIENTE
),
RFM_Scored AS (
    SELECT
        CodigoCliente, Recency, Frequency, Monetary,
        CASE
            WHEN Recency &lt;=  30 THEN 5
            WHEN Recency &lt;=  60 THEN 4
            WHEN Recency &lt;=  90 THEN 3
            WHEN Recency &lt;= 180 THEN 2
            ELSE 1
        END AS PuntajeR,
        CASE
            WHEN Frequency &gt;= 20 THEN 5
            WHEN Frequency &gt;= 10 THEN 4
            WHEN Frequency &gt;=  5 THEN 3
            WHEN Frequency &gt;=  1 THEN 2
            ELSE 1
        END AS PuntajeF,
        CASE
            WHEN Monetary &gt;= 50000 THEN 5
            WHEN Monetary &gt;= 20000 THEN 4
            WHEN Monetary &gt;=  5000 THEN 3
            WHEN Monetary &gt;=   500 THEN 2
            ELSE 1
        END AS PuntajeM
    FROM RFM
)
SELECT
    CodigoCliente,
    YEAR(GETDATE()) * 100 + MONTH(GETDATE()) AS CodigoTiempo,
    Recency, Frequency, Monetary,
    PuntajeR, PuntajeF, PuntajeM,
    CASE
        WHEN (PuntajeR + PuntajeF + PuntajeM) &gt;= 13 THEN 'Champions'
        WHEN (PuntajeR + PuntajeF + PuntajeM) &gt;= 10 THEN 'Loyal'
        WHEN (PuntajeR + PuntajeF + PuntajeM) &gt;=  7 THEN 'Potential'
        WHEN (PuntajeR + PuntajeF + PuntajeM) &gt;=  5 THEN 'At Risk'
        ELSE 'Lost'
    END AS SegmentoCliente
FROM RFM_Scored;</property>
