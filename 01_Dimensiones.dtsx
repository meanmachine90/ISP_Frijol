                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    ID_CONCEPTO AS CodigoConcepto,
    NOMBRE      AS NombreConcepto,
    CASE
        WHEN TIPO = 'I' THEN 'Ingreso'
        WHEN TIPO = 'D' THEN 'Deduccion'
        ELSE 'Otro'
    END AS TipoConcepto,
    CASE WHEN OBLIGATORIO = 1 THEN 'Si' ELSE 'No' END AS Obligatorio
FROM DbMultidimensionales_Proyecto3_Frijol.dbo.CONCEPTOS_PAGO;</property>
