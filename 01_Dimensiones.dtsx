                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 1 AS CodigoFormaPago, 'EFECTIVO'      AS NombreFormaPago, 'Pago en efectivo'       AS Descripcion UNION ALL
SELECT 2, 'TARJETA',        'Pago con tarjeta'       UNION ALL
SELECT 3, 'TRANSFERENCIA',  'Transferencia bancaria' UNION ALL
SELECT 4, 'CREDITO',        'Credito comercial'      UNION ALL
SELECT 5, 'CHEQUE',         'Pago con cheque';</property>
