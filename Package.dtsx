            <component
              refId="Package\Hechos_Ventas\Origen de ADO NET"
              componentClassID="Microsoft.ManagedComponentHost"
              contactInfo="Consume datos de SQL Server, OLE DB, ODBC u Oracle mediante el correspondiente proveedor de datos de .NET Framework. Se usa una instrucción Transact-SQL para definir el conjunto de resultados. Por ejemplo, se extraen datos de SQL Server con el proveedor de datos de .NET Framework para SQL Server.;Microsoft Corporation; Microsoft SQL Server; © Microsoft Corporation; Todos los derechos reservados; http://www.microsoft.com/sql/support;4"
              description="Consume datos de SQL Server, OLE DB, ODBC u Oracle mediante el correspondiente proveedor de datos de .NET Framework. Se usa una instrucción Transact-SQL para definir el conjunto de resultados. Por ejemplo, se extraen datos de SQL Server con el proveedor de datos de .NET Framework para SQL Server."
              name="Origen de ADO NET"
              usesDispositions="true"
              version="4">
              <properties>
                <property
                  dataType="System.String"
                  description="Especifica la instrucción SQL utilizada por el componente para extraer datos."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    v.ID_CLIENTE AS CodigoCliente,
    v.ID_EMPLEADO AS CodigoEmpleado,
    vd.ID_PRODUCTO AS CodigoProducto,
    (SELECT TOP 1 co.ID_PROVEEDOR
     FROM DbMultidimensionales_Proyecto3_Frijol.dbo.COMPRAS_DETALLE cd2
     INNER JOIN DbMultidimensionales_Proyecto3_Frijol.dbo.COMPRAS co ON cd2.ID_COMPRA = co.ID_COMPRA
     WHERE cd2.ID_PRODUCTO = vd.ID_PRODUCTO ORDER BY co.FECHA_COMPRA DESC) AS CodigoProveedor,
    YEAR(v.FECHA_VENTA) * 100 + MONTH(v.FECHA_VENTA) AS CodigoTiempo,
    (SELECT TOP 1 pr.ID_SOCIO
     FROM DbMultidimensionales_Proyecto3_Frijol.dbo.PRODUCCION pr
     WHERE pr.ID_PRODUCTO = vd.ID_PRODUCTO ORDER BY pr.FECHA_COSECHA DESC) AS CodigoSocio,
    (SELECT TOP 1 pr.ID_CICLO
     FROM DbMultidimensionales_Proyecto3_Frijol.dbo.PRODUCCION pr
     WHERE pr.ID_PRODUCTO = vd.ID_PRODUCTO ORDER BY pr.FECHA_COSECHA DESC) AS CodigoCiclo,
    -1 AS CodigoConcepto,
    -1 AS CodigoInstitucion,
    cl.ID_MUNICIPIO AS CodigoUbicacion,
    p.ID_CATEGORIA AS CodigoCategoria,
    fp.CodigoFormaPago AS CodigoFormaPago,
    vd.CANTIDAD AS Cantidad,
    vd.PRECIO_UNITARIO AS PrecioUnitario,
    vd.DESCUENTO AS Descuento,
    (vd.CANTIDAD * vd.PRECIO_UNITARIO) - vd.DESCUENTO AS Subtotal,
    vd.CANTIDAD * hp.PRECIO_COMPRA AS CostoTotal,
    ((vd.CANTIDAD * vd.PRECIO_UNITARIO) - vd.DESCUENTO) - (vd.CANTIDAD * hp.PRECIO_COMPRA) AS Margen
FROM DbMultidimensionales_Proyecto3_Frijol.dbo.VENTAS v
INNER JOIN DbMultidimensionales_Proyecto3_Frijol.dbo.VENTAS_DETALLE vd ON v.ID_VENTA = vd.ID_VENTA
INNER JOIN DbMultidimensionales_Proyecto3_Frijol.dbo.CLIENTES cl ON v.ID_CLIENTE = cl.ID_CLIENTE
INNER JOIN DbMultidimensionales_Proyecto3_Frijol.dbo.PRODUCTOS p ON vd.ID_PRODUCTO = p.ID_PRODUCTO
INNER JOIN DbMultidimensionales_Proyecto3_Frijol.dbo.HISTORIAL_PRECIOS hp ON vd.ID_HISTORIAL_PRECIO = hp.ID_HISTORIAL
INNER JOIN Dw_FormaPago fp ON fp.NombreFormaPago = v.FORMA_PAGO;</property>
                <property
                  dataType="System.Int32"
                  description="Número de segundos antes de que se agote el tiempo de espera de un comando. Un valor de 0 indica un tiempo de espera infinito."
                  name="CommandTimeout">30</property>
                <property
                  dataType="System.Boolean"
                  description="Indica si se debe permitir que columnas externas que no sean de cadenas se conviertan implícitamente en cadenas en las columnas de salida."
                  name="AllowImplicitStringConversion">true</property>
                <property
