                  description="Especifica la instrucción SQL utilizada por el componente para extraer datos."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    e.ID_EMPLEADO AS CodigoEmpleado,
    LTRIM(RTRIM(e.NOMBRES + ' ' + e.APELLIDOS)) AS NombreCompleto,
    ce.NOMBRE AS Cargo,
    ce.SALARIO_BASE AS SueldoBasico
FROM DbMultidimensionales_Proyecto3_Frijol.dbo.EMPLEADOS e
INNER JOIN DbMultidimensionales_Proyecto3_Frijol.dbo.CARGOS_EMPLEADO ce ON e.ID_CARGO_EMPLEADO = ce.ID_CARGO_EMPLEADO;</property>
